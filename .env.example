# 🐙 Octopus — Variables d'environnement
# Copier ce fichier en .env et éditer les valeurs
# cp .env.example .env

# ─── Orchestrator ─────────────────────────────────────
ORCHESTRATOR_HOST=orchestrator
ORCHESTRATOR_PORT=9091
LOG_LEVEL=info

# ─── Engine (Python/RL) ──────────────────────────────
JAX_PLATFORM_NAME=gpu        # gpu ou cpu
TRAINING_STEPS=30000          # Nombre de pas d'entraînement
REPLAY_BUFFER_SIZE=100000     # Taille du replay buffer
BATCH_SIZE=128                # Taille des mini-batchs
LEARNING_RATE=5e-5            # Learning rate global

# ─── Execution (Rust/MT5) ────────────────────────────
MT5_LOGIN=                    # Login MT5 (laisser vide pour simulation)
MT5_PASSWORD=                 # Password MT5
MT5_SERVER=                   # Serveur MT5 (ex: FTMO-Demo)

# ─── Macro (Calendrier/Sentiment/CB) ─────────────────
USE_FINBERT=false             # true = utilise FinBERT (nécessite transformers)
MACRO_CACHE_TTL_HOURS=1       # Durée du cache macro en heures

# ─── Invest (Trade Republic) ─────────────────────────
TR_PHONE=                     # Numéro de téléphone Trade Republic
TR_PIN=                       # PIN Trade Republic
INVEST_STRATEGY=core_satellite # core_satellite, three_fund, boglehead, all_weather
MONTHLY_BUDGET=300            # Budget mensuel d'investissement (€)

# ─── Quant (Julia) ───────────────────────────────────
JULIA_NUM_THREADS=32          # Threads Julia pour calculs HPC

# ─── Web Dashboard ──────────────────────────────────
VITE_ORCHESTRATOR_WS=ws://localhost:8080/ws

# ─── Notes ────────────────────────────────────────────
# Pour utiliser le GPU : installer nvidia-container-toolkit
# Pour activer FinBERT : USE_FINBERT=true (nécessite ~2GB RAM)
# Pour le mode démo : laisser MT5_LOGIN/MT5_PASSWORD vides